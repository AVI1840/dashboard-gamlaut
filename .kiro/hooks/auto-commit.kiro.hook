{
  "enabled": true,
  "name": "auto-commit",
  "description": "Automatically stages and commits all changes after each agent task completes",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "git add . && git commit -m \"update by kiro agent\""
  }
}